# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is gitignored.
#
# This project has TWO Supabase environments:
#   • Production: project-ref twfispazhjiqxabymjiv  (real users, real data)
#   • Staging:    project-ref qskevpfxmvdlykollnod  (smoke testing only)
#
# For local development, point .env.local at STAGING by default. Only point at
# production when you have a specific reason (e.g. reproducing a prod-only
# bug), and switch back as soon as you are done.
#
# Get values from:
#   Supabase dashboard → <project> → Settings → API
#
# In Vercel, these same vars are set per-environment:
#   • Production env vars  → fire on `main` branch deploys
#   • Preview env vars     → fire on `staging` branch deploys (and other PRs)

# ── Supabase (required for all features) ────────────────────────────────────
# Default: staging URL
NEXT_PUBLIC_SUPABASE_URL=https://qskevpfxmvdlykollnod.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-key-here

# ── Service role (seed script + admin server actions only) ───────────────────
# WARNING: this key bypasses RLS. Never expose it to the browser.
# Used by: scripts/seed-lookup-data.ts and src/lib/supabase/admin.ts
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key-here
