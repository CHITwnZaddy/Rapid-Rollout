# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is gitignored.

# ── Supabase (required for all features) ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Service role (seed script + admin server actions only) ───────────────────
# WARNING: this key bypasses RLS. Never expose it to the browser.
# Used by: scripts/seed-lookup-data.ts and src/lib/supabase/admin.ts
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
